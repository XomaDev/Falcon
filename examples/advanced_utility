func FilterByLength(textList, len) = {
  // Filters strings where the length is equal to 'len'
  textList.filter { text -> text.textLen() == len }
}
----
func MaxTextByLength(textList) = {
  // Finds the longest string using the max lambda based on textLen()
  // The lambda { m, n -> n.textLen() > m.textLen() } means n is 'greater' (longer) than m
  textList.max { m, n -> n.textLen() > m.textLen() }
}
