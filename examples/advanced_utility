func FormatPrice(num) = {
  // Formats a number to exactly two decimal places
  formatDecimal(num, 2)
}
----
func SumOfTextLengths(textList) = {
  // 1. Map: Convert each string to its length (a number)
  // 2. Reduce: Sum up all the lengths, starting with 0
  textList
    .map { text -> text.textLen() }
    .reduce(0) { length, soFar -> length + soFar }
}
