func GetQuartile(dataList) = {
  // Finds the first quartile (Q1), which is the median of the lower half of the data.
  local sortedList = copyList(dataList).sort()
  local len = sortedList.listLen()

  // N/4, rounded up. Using slice for the lower half.
  local q1Index = floor(len / 4)

  // To keep logic simple and rely on existing functions, we will find the median of the first half.
  // Falcon is 1-based, slicing up to the index of the median for the full list.
  local medianIndex = (len + 1) / 2

  // Calculate the length of the lower half to determine the slice end point (1-based index)
  local lowerHalfEnd = floor(len / 2)

  // Slice the lower half of the list (from index 1 to lowerHalfEnd)
  local lowerHalf = sortedList.slice(1, lowerHalfEnd)

  // Q1 is the median of the lower half. We reuse the logic from FindMedian.
  local halfLen = lowerHalf.listLen()

  if (halfLen % 2 != 0) {
    // Odd length lower half
    local middleIndex = (halfLen + 1) / 2
    lowerHalf[middleIndex]
  } else {
    // Even length lower half
    local index1 = halfLen / 2
    local index2 = (halfLen / 2) + 1
    (lowerHalf[index1] + lowerHalf[index2]) / 2
  }
}