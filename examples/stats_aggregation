func FindMode(numList) = {
  // Uses the built-in modeOf() function
  modeOf(numList)
}
----
func FindRange(numList) = {
  // Range = max(list) - min(list)
  maxOf(numList) - minOf(numList)
}
----
func SumListLambda(numList) = {
  // Calculates the sum using the reduce lambda starting with an initial value of 0
  numList.reduce(0) { x, soFar -> x + soFar }
}
----
func CountNegative(numList) = {
  // Filters the list to keep only elements less than 0, then finds the length of the resulting list
  numList
    .filter { n -> n < 0 }
    .listLen()
}
----
func StandardDeviation(numList) = {
  // Uses the built-in stdDevOf() function
  stdDevOf(numList)
}
----
func GeometricMean(numList) = {
  // Uses the built-in geoMeanOf() function
  geoMeanOf(numList)
}
----
func FindMaxLambda(numList) = {
  // Finds the maximum element using the max lambda.
  // The lambda { m, n -> n > m } defines the comparison: n is "greater" than m.
  numList.max { m, n -> n > m }
}
----
func SquareAll(numList) = {
  // Returns a new list with all elements squared using the map lambda
  numList.map { n -> n ^ 2 }
}