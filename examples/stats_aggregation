func CalculateMean(numList) = {
  // Uses the built-in avgOf() function
  avgOf(numList)
}
----
func FindMedian(numList) = {
  // Sort the list first
  local sortedList = copyList(numList).sort()
  local len = sortedList.listLen()

  if (len % 2 != 0) {
    // Odd length: median is the middle element.
    // Falcon is 1-based, so the index is (len + 1) / 2
    local middleIndex = (len + 1) / 2
    sortedList[middleIndex]
  } else {
    // Even length: median is the average of the two middle elements.
    local index1 = len / 2
    local index2 = (len / 2) + 1

    // Calculate the average of the two middle elements
    (sortedList[index1] + sortedList[index2]) / 2
  }
}
