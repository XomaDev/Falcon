func CheckHex(text) = {
  // Checks if 'text' is a valid hexadecimal number string using the question operator
  text ? hexa
}
----
func ConvertBinToDec(binText) = {
  // Converts a binary string to a decimal number
  binToDec(binText)
}
----
func DecToHex(number) = {
  // Converts a decimal number to a hexadecimal string
  decToHex(number)
}
----
func SafeDivide(a, b) = {
  // Returns a/b, or 0 if b is 0, using an if-else statement
  if (b == 0) {
    0
  } else {
    a / b
  }
}