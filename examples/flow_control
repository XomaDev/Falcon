func CheckIsNumber(value) = {
  // Checks if 'value' is of type number using the question operator
  value ? number
}
----
func CheckIsList(value) = {
  // Checks if 'value' is of type list using the question operator
  value ? list
}
----
func CheckEmptyList(value) = {
  // Checks if 'value' is an empty list using the question operator
  value ? emptyList
}
----
func IfElseResult(a, b) = {
  // Uses the if-else expression to return the greater of 'a' and 'b'
  if (a > b) a else b
}
----
func SumToN(n) = {
  local sum = 0
  local i = 1
  
  // Sums numbers from 1 up to n using a while loop
  while (i <= n) {
    sum = sum + i
    i = i + 1
  }
  
  // The last expression is returned
  sum
}
----
func IterateAndBreak(list) = {
  // Iterates the list. Prints elements until "Stop" is found, then breaks.
  for (item in list) {
    if (item === "Stop") { // Use === for text equality
      break
    }
    println(item)
  }
}
