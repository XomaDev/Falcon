func PowerOfN(base, exponent) = {
  // Use the built-in power operator ^
  base ^ exponent
}
----
func Factorial(n) = {
  // Base case: 0! is 1
  if (n == 0) {
    1
  } else {
    // Recursive step: n! = n * (n - 1)!
    n * Factorial(n - 1)
  }
}
----
func GCD(a, b) = {
  // Base case: if b is 0, GCD is a
  if (b == 0) {
    a
  } else {
    // Recursive step: GCD(a, b) = GCD(b, a % b)
    GCD(b, a % b)
  }
}
----
func GCD(a, b) = {
  // Base case: if b is 0, GCD is a
  if (b == 0) {
    a
  } else {
    // Recursive step: GCD(a, b) = GCD(b, a % b)
    GCD(b, a % b)
  }
}
func LCM(a, b) = {
  // Formula: (abs(a * b)) / GCD(a, b)
  abs(a * b) / GCD(a, b)
}
