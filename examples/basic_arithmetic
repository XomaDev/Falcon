func IsDivisibleBy(n, d) = {
  // If the remainder is 0, it is perfectly divisible
  n % d == 0
}
----
func IsPerfectNumber(n) = {
  // Proper divisors start from 1 up to n-1
  local sumOfDivisors = 0

  // Iterate from 1 up to n-1 (1-based indexing for range)
  for (i: 1 .. n - 1) {
    if (n % i == 0) {
      sumOfDivisors = sumOfDivisors + i
    }
  }

  // A perfect number equals the sum of its proper divisors
  sumOfDivisors == n
}
