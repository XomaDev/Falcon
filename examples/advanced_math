func QuadraticRoot1(a, b, c) = {
  // Calculates the discriminant (D) = b^2 - 4ac
  local discriminant = (b ^ 2) - (4 * a * c)

  // First root: (-b + sqrt(D)) / (2a). Assumes D >= 0.
  (-b + sqrt(discriminant)) / (2 * a)
}
