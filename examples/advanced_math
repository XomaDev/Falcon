func FindMaxKey(myDict) = {
  local maxKey = ""
  local maxValue = null
  local first = true

  // Iterate through key-value pairs
  for (key, value in myDict) {
    if (value ? number) { // Ensure the value is a number before comparison
      if (first) {
        maxValue = value
        maxKey = key
        first = false
      } else if (value > maxValue) {
        maxValue = value
        maxKey = key
      }
    }
  }
  // Returns the key associated with the maximum numerical value
  maxKey
}
