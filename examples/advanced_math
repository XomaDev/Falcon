func SumListReduce(numList) = {
  // Calculates the sum using the reduce lambda
  numList.reduce(0) { x, soFar -> x + soFar }
}
----
func SquareAllMap(numList) = {
  // Returns a new list with all elements squared
  numList.map { n -> n ^ 2 }
}
----
func SortAbsolute(numList) = {
  // Sorts the list based on the absolute value of its elements
  // The expression abs(m) < abs(n) means m precedes n if |m| is less than |n| (ascending by abs value)
  numList.sort { m, n -> abs(m) < abs(n) }
}
