func PrimeCheck(n) = {
  if (n <= 1) {
    false
  } else if (n <= 3) {
    true
  } else if (n % 2 == 0) {
    false
  } else {
    local limit = floor(sqrt(n))
    local i = 3 // Start checking from 3 (already checked 2)
    local isPrime = true

    while (i <= limit) {
      if (n % i == 0) {
        isPrime = false
        break
      }
      // Check only odd divisors
      i = i + 2
    }
    isPrime
  }
}
