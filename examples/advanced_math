func GCD(a, b) = {
    // Ensure a and b are non-negative for this basic implementation
    local a_val = abs(a)
    local b_val = abs(b)

    // Check if both are zero
    if (a_val == 0 && b_val == 0) {
        // Technically undefined or 0 depending on context; we'll return 0
        0
    } else {
        // Euclidean Algorithm using a while loop
        while (b_val != 0) {
            local remainder = a_val % b_val
            // a_val becomes the old b_val
            a_val = b_val
            // b_val becomes the remainder
            b_val = remainder
        }
        // The last non-zero value of a_val is the GCD
        a_val
    }
}
