func FibIterative(n) = {
  if (n <= 1) {
    n
  } else {
    local a = 0
    local b = 1
    local result = 1

    // Loop from the 2nd term up to the n-th term (1-based index)
    for (i: 2 .. n) {
      result = a + b
      a = b
      b = result
    }
    result
  }
}
