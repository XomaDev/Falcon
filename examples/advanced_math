func SumInverse(numList) = {
  // 1. Map: Calculates the inverse (1/n) for each element
  // 2. Reduce: Sums the resulting inverse values, starting with 0
  numList
    .map { n -> 1 / n }
    .reduce(0) { inverse, soFar -> inverse + soFar }
}