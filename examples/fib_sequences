func CheckPerfectSquare(n) = {
  // A number n is a perfect square if sqrt(n) is an integer.
  // We can check this by seeing if the rounded result equals the original sqrt result.
  // Alternatively, check if the rounded result squared equals the original number.
  local s = sqrt(n)

  // Use round() to get the nearest integer value of the square root
  s == round(s)

  // Alternative check: round(s) ^ 2 == n (If n is a positive number)
}