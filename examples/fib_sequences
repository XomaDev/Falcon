func FibIterative(n) = {
  if (n <= 1) {
    n
  } else {
    local a = 0  // Represents F(i-2)
    local b = 1  // Represents F(i-1)
    local result = 0

    // Loop from the 2nd term up to the n-th term
    // Since Falcon uses 1-based indexing, we run the loop n-1 times
    for (i: 2 .. n) {
      result = a + b
      a = b
      b = result
    }
    // The last calculated result (b) is the n-th Fibonacci number
    result
  }
}
