func CollatzNext(n) = {
  if (n % 2 == 0) {
    // If n is even, next is n / 2
    n / 2
  } else {
    // If n is odd, next is 3 * n + 1
    3 * n + 1
  }
}
----
func CubeOfN(n) = {
  // Calculates n^3
  n ^ 3
}
