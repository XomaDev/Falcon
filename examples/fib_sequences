func GeometricTerm(a, r, n) = {
  // Formula: a * r^(n-1). n is 1-based.
  a * (r ^ (n - 1))
}
----
func ArithmeticTerm(a, d, n) = {
  // Formula: a + (n-1)d. n is 1-based.
  a + ((n - 1) * d)
}
----
func SumOfFirstN(n) = {
  // Formula for the sum of the first n natural numbers: n * (n + 1) / 2
  n * (n + 1) / 2
}
----
func SumOfPowersOfTwo(n) = {
  // Formula for 1 + 2 + 4 + ... + 2^n is 2^(n+1) - 1
  (2 ^ (n + 1)) - 1
}
----
func LucasNumber(n) = {
  // Base cases: L(0)=2, L(1)=1.
  if (n == 0) {
    2
  } else if (n == 1) {
    1
  } else {
    // Recursive step: L(n) = L(n-1) + L(n-2)
    LucasNumber(n - 1) + LucasNumber(n - 2)
  }
}
